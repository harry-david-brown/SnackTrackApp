{
  "name": "snack-track-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --port 8082",
    "start:clean": "pkill -f 'expo start' || pkill -f 'metro' || true; sleep 2; expo start --port 8082",
    "web": "expo start --web --port 8082",
    "stop-expo": "pkill -f 'expo start' || pkill -f 'metro' || true",
    "dev": "expo start --dev-client",
    "build:ios": "expo build:ios",
    "setup": "chmod +x scripts/setup.sh && ./scripts/setup.sh",
    "setup:quick": "npm install --legacy-peer-deps && cp .env.development .env && npm run db:start",
    "db:start": "docker-compose -f docker-compose.dev.yml up -d",
    "db:stop": "docker-compose -f docker-compose.dev.yml down",
    "db:reset": "docker-compose -f docker-compose.dev.yml down -v && docker-compose -f docker-compose.dev.yml up -d",
    "db:logs": "docker-compose -f docker-compose.dev.yml logs -f postgres",
    "lint": "expo lint",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "clean": "rm -rf node_modules package-lock.json && npm install --legacy-peer-deps",
    "doctor": "expo doctor",
    "verify": "node scripts/verify-setup.js"
  },
  "dependencies": {
    "@expo/ngrok": "^4.1.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "^11.4.1",
    "@tanstack/react-query": "^5.90.2",
    "axios": "^1.12.2",
    "expo": "~54.0.10",
    "expo-document-picker": "~14.0.7",
    "expo-file-system": "~19.0.15",
    "expo-linear-gradient": "~15.0.7",
    "expo-media-library": "~18.2.0",
    "expo-router": "~6.0.8",
    "expo-sharing": "~14.0.7",
    "expo-status-bar": "~3.0.8",
    "nativewind": "^4.2.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.4",
    "react-native-chart-kit": "^6.12.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-svg": "15.12.1",
    "react-native-view-shot": "4.0.3",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^12.0.0",
    "@types/jest": "^29.5.0",
    "@types/react": "~19.1.10",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~10.0.0",
    "jest": "^29.5.0",
    "jest-expo": "~54.0.12",
    "typescript": "~5.9.2"
  },
  "private": true
}

{
  "name": "snack-track-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "node scripts/validate-env.js && expo start --port 8081",
    "start:clean": "pkill -f 'expo start' || pkill -f 'metro' || true; sleep 2; node scripts/validate-env.js && expo start --port 8082",
    "web": "expo start --web --port 8082",
    "stop-expo": "pkill -f 'expo start' || pkill -f 'metro' || true",
    "dev": "expo start --dev-client",
    "build:ios": "expo build:ios",
    "setup": "chmod +x scripts/setup.sh && ./scripts/setup.sh",
    "setup:quick": "npm install --legacy-peer-deps && cp .env.development .env && npm run db:start",
    "db:start": "docker-compose -f docker-compose.dev.yml up -d",
    "db:stop": "docker-compose -f docker-compose.dev.yml down",
    "db:reset": "docker-compose -f docker-compose.dev.yml down -v && docker-compose -f docker-compose.dev.yml up -d",
    "db:logs": "docker-compose -f docker-compose.dev.yml logs -f postgres",
    "lint": "expo lint",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "ci": "npm run type-check && npm run lint && npm test -- --watchAll=false",
    "audit": "npm audit --audit-level=moderate",
    "clean": "rm -rf node_modules package-lock.json && npm install --legacy-peer-deps",
    "doctor": "expo doctor",
    "verify": "node scripts/verify-setup.js",
    "prepare": "husky",
    "analyze:bundle": "node scripts/analyze-bundle-size.js",
    "export:ios": "expo export --platform ios",
    "export:android": "expo export --platform android",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "^11.4.1",
    "@sentry/react-native": "^7.7.0",
    "@tanstack/react-query": "^5.90.2",
    "axios": "^1.12.2",
    "expo": "~54.0.22",
    "expo-auth-session": "^7.0.9",
    "expo-av": "^16.0.7",
    "expo-constants": "~18.0.10",
    "expo-dev-client": "~6.0.17",
    "expo-document-picker": "~14.0.7",
    "expo-linear-gradient": "~15.0.7",
    "expo-linking": "~8.0.8",
    "expo-localization": "^17.0.7",
    "expo-router": "~6.0.14",
    "expo-secure-store": "^15.0.7",
    "expo-sharing": "~14.0.7",
    "expo-status-bar": "~3.0.8",
    "expo-web-browser": "^15.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-chart-kit": "^6.12.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-view-shot": "4.0.3",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^12.0.0",
    "@types/jest": "^29.5.0",
    "@types/react": "~19.1.10",
    "eas-cli": "^16.28.0",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~10.0.0",
    "husky": "^9.1.7",
    "jest": "^29.5.0",
    "jest-expo": "~54.0.13",
    "lint-staged": "^16.2.3",
    "typescript": "~5.9.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix"
    ]
  },
  "private": true
}

# Snack Track Mobile App - Environment Configuration
# Copy this file to .env and configure for your setup

# =============================================================================
# API Configuration
# =============================================================================

# Local Development (testing on same machine)
# EXPO_PUBLIC_API_URL=http://localhost:3000

# Mobile Device Testing (replace with your computer's local IP)
# Find your IP: ip addr show (Linux) or ipconfig (Windows) or ifconfig (Mac)
# EXPO_PUBLIC_API_URL=http://192.168.1.100:3000

# Production
# EXPO_PUBLIC_API_URL=https://api.snacktrack.com

# =============================================================================
# Development Notes
# =============================================================================
# - For Expo Go on physical device: Use your computer's local IP address
# - For iOS Simulator: Use http://localhost:3000
# - For Android Emulator: Use http://10.0.2.2:3000
# - For Production: Use your production API URL
